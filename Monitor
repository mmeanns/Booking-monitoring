name: Crystal Sports Booking Monitor
on:
  workflow_dispatch: {}
  push:
    branches: [main]
permissions:
  contents: read
  actions: write
jobs:
  check-availability:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.x'
      - name: Install dependencies
        run: pip install requests
      - name: Restore state cache
        uses: actions/cache@v4
        with:
          path: known_free_slots.json
          key: booking-state
          restore-keys: |
            booking-state-
      - name: Run monitor
        env:
          SMTP_USER: ${{ secrets.SMTP_USER }}
          SMTP_PASSWORD: ${{ secrets.SMTP_PASSWORD }}
          EMAIL_TO: ${{ secrets.EMAIL_TO }}
          NTFY_TOPIC: ${{ secrets.NTFY_TOPIC }}
          BOOKING_COOKIES_JSON: ${{ secrets.BOOKING_COOKIES_JSON }}
        run: python monitor_booking.py
      - name: Delete old cache entry
        if: always()
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: gh cache delete booking-state || true
      - name: Save state cache
        if: always()
        uses: actions/cache/save@v4
        with:
          path: known_free_slots.json
          key: booking-state
